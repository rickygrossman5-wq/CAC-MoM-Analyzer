<body>
<div class="grain"></div>
<div class="err-banner" id="err-banner" hidden></div>

<header class="masthead">
  <div class="tick"></div>
  <span class="eyebrow">PLTFRM · NEW-TO-BRAND · MONTH OVER MONTH</span>
  <nav class="page-nav">
    <a href="index.html" class="active">MoM Movement</a>
    <a href="deepdive.html">SP Deep Dive</a>
  </nav>
</header>

<section class="hero">
  <h1 class="hero-title">CAC<span class="hero-rule">/</span>Movement</h1>
  <p class="hero-sub">Drop two new-to-brand campaign exports. We hold spend, customer acquisition cost, NTB sales and share up to the light and show you where the month actually moved — by category, by campaign, and what to do next.</p>
</section>

<!-- STAGE 0: COPY AMC QUERY -->
<section class="stage query-stage" id="query-stage">
  <div class="stage-index"><span>00</span><span class="stage-name">Copy AMC query — Campaign NTB report</span></div>
  <p class="stage-note">Run this query in your brand's AMC instance to generate the two CSVs this page needs (one per month).</p>
  <div class="query-grid">
    <div class="query-box">
      <div class="query-toolbar">
        <span class="query-tag">Campaign NTB report</span>
        <button class="ghost-btn copy-btn" id="copy-query">Copy query</button>
      </div>
      <pre class="query-code" id="query-text">-- Campaign NTB query will be provided here --</pre>
    </div>
    <ol class="query-steps">
      <li>Copy the query above.</li>
      <li>Log in to your brand's <strong>AMC</strong> instance.</li>
      <li>Open the <strong>Query editor</strong>.</li>
      <li>Paste the query and set the date range.</li>
      <li><strong>Run it twice</strong> — once for the <em>previous month</em>, once for the <em>current month</em>.</li>
      <li>Download both CSVs and drop them below (earlier month on the left, later on the right).</li>
    </ol>
  </div>
</section>

<!-- STAGE 1: UPLOAD -->
<section class="stage" id="upload-stage">
  <div class="stage-index"><span>01</span><span class="stage-name">Load the months</span></div>
  <div class="upload-grid">
    <label class="drop" id="drop-early">
      <input type="file" accept=".csv" id="file-early" hidden>
      <span class="drop-period">Earlier period</span>
      <span class="drop-cue" id="cue-early">Click or drop a CSV</span>
      <span class="drop-file" id="name-early"></span>
    </label>
    <div class="arrow">→</div>
    <label class="drop" id="drop-late">
      <input type="file" accept=".csv" id="file-late" hidden>
      <span class="drop-period">Later period</span>
      <span class="drop-cue" id="cue-late">Click or drop a CSV</span>
      <span class="drop-file" id="name-late"></span>
    </label>
  </div>
  <div class="label-row">
    <div class="field"><label for="label-early">Earlier label</label><input type="text" id="label-early" placeholder="e.g. April"></div>
    <div class="field"><label for="label-late">Later label</label><input type="text" id="label-late" placeholder="e.g. May"></div>
  </div>
</section>

<!-- STAGE 2: CATEGORIES -->
<section class="stage" id="cat-stage">
  <div class="stage-index"><span>02</span><span class="stage-name">Define categories</span>
    <label class="skip-toggle"><input type="checkbox" id="skip-cats"> <span>Skip — analyze without categories</span></label>
  </div>
  <p class="stage-note">A campaign joins a category if its name contains any of the terms below (case-insensitive). Comma-separate terms. Edit, remove, or add rows to match your account. Optional — you can run the report with no categories at all.</p>
  <div id="cat-body">
    <div id="cat-rows"></div>
